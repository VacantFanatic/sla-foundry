{
  "name": "sla-industries",
  "version": "2.4.4",
  "description": "CSS compiler for the SLA Industries system",
  "scripts": {
    "build": "sass src/scss/sla-industries.scss css/sla-industries.css --style=expanded --no-source-map",
    "watch": "sass src/scss/sla-industries.scss css/sla-industries.css --style=expanded --no-source-map --watch",
    "test:unit": "node --test tests/unit/inventory-stack.test.mjs tests/unit/system-manifest.test.mjs tests/unit/dice.test.mjs tests/unit/chat-wound-options.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:regression": "playwright test tests/e2e/regression-sla.spec.js",
    "test:e2e:operators": "playwright test tests/e2e/regression-operators.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "VacantFanatic",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "glob": "^10.3.10",
    "inquirer": "^9.2.15",
    "prompt": "^1.3.0",
    "renamer": "^5.0.0",
    "replace": "^1.2.2",
    "sass": "^1.53.0"
  }
}

<header class="sheet-header">
    <div class="header-grid">

        <div class="header-left">
            <h1 class="charname">
                <input name="name" type="text" value="{{actor.name}}" placeholder="Operative Name" />
            </h1>

            <div class="header-fields">
                <div class="form-group sla-field">
                    <label class="label-bold open-compendium" data-compendium="sla-industries.species"
                        title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.Species"}}</label>
                    <div class="chip sla-drop {{#if speciesItem}}sla-drop--filled{{/if}}">
                        {{#if speciesItem}}
                        <img src="{{speciesItem.img}}" alt="" />
                        <span class="chip-name">{{speciesItem.name}}</span>
                        <a class="chip-delete" data-type="species" title="{{localize 'SLA.ActorSheet.RemoveChip'}}" aria-label="{{localize 'SLA.ActorSheet.RemoveChip'}}"><i class="fas fa-times"></i></a>
                        {{else}}
                        <div class="chip-placeholder open-compendium sla-drop" data-compendium="sla-industries.species"
                            title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.DropSpecies"}}</div>
                        {{/if}}
                    </div>
                </div>

                <div class="form-group sla-field">
                    <label class="label-bold open-compendium" data-compendium="sla-industries.packages"
                        title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.Package"}}</label>
                    <div class="chip sla-drop {{#if packageItem}}sla-drop--filled{{/if}}">
                        {{#if packageItem}}
                        <img src="{{packageItem.img}}" alt="" />
                        <span class="chip-name">{{packageItem.name}}</span>
                        <a class="chip-delete" data-type="package" title="{{localize 'SLA.ActorSheet.RemoveChip'}}" aria-label="{{localize 'SLA.ActorSheet.RemoveChip'}}"><i class="fas fa-times"></i></a>
                        {{else}}
                        <div class="chip-placeholder open-compendium sla-drop" data-compendium="sla-industries.packages"
                            title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.DropPackage"}}</div>
                        {{/if}}
                    </div>
                </div>
            </div>

            <div class="header-bottom-bar">
                <div class="lad-wrapper sla-field sla-field--toggle">
                    <label for="lad-check" title="{{localize 'SLA.ActorSheet.LADHint'}}">{{localize "SLA.ActorSheet.LAD"}}</label>
                    <input type="checkbox" id="lad-check" name="system.bio.lad" {{checked system.bio.lad}} />
                </div>

                <div class="scl-wrapper sla-field sla-field--inline">
                    <label title="{{localize 'SLA.ActorSheet.SCLHint'}}">{{localize "SLA.ActorSheet.SCL"}}</label>
                    <input type="text" name="system.bio.scl" value="{{system.bio.scl}}" data-dtype="String" />
                </div>
            </div>
        </div>

        <div class="portrait-container">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}" />
        </div>

        <details class="finance-box sla-finance-details" open>
            <summary>{{localize "SLA.ActorSheet.Finance"}}</summary>
            <div class="sla-pad sla-finance-fields">
                <div class="sla-field sla-field--finance-credits">
                    <label>{{localize "SLA.ActorSheet.Credits"}}</label>
                    <input type="number" name="system.finance.credits" value="{{system.finance.credits}}" />
                </div>
                <div class="sla-field">
                    <label>{{localize "SLA.ActorSheet.Unis"}}</label>
                    <input type="number" name="system.finance.unis" value="{{system.finance.unis}}" />
                </div>
                <div class="sla-field sla-field--finance-debt">
                    <label>{{localize "SLA.ActorSheet.Debt"}}</label>
                    <input type="number" name="system.finance.debt" value="{{system.finance.debt}}" />
                </div>
            </div>
        </details>

    </div>
</header>

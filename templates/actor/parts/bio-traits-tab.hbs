<div class="flexcol full-height">
    {{!-- Traits --}}
    <div class="sla-panel" style="flex: 0 0 200px; margin-bottom: 5px;">
        <div class="sla-header-bar flexrow">
            <span style="flex:1; cursor: pointer;" class="open-compendium" data-compendium="sla-industries.traits"
                title="Open Compendium">TRAITS</span>
        </div>
        <div class="scroll-list">
            <table class="sla-table">
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 5px;">Name</th>
                        <th style="width: 50px;">Rank</th>
                        <th style="width: 120px;">Type</th>
                        <th style="width: 50px;">Cost</th>
                        <th style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each traits as |trait|}}
                    <tr class="item" data-item-id="{{trait._id}}">
                        <td class="item-name rollable" data-roll-type="item" style="font-weight: bold; color: #fff; padding-left: 5px;">{{trait.name}}</td>
                        <td style="text-align: center;">{{trait.system.rank}}</td>
                        <td style="text-align: center;">{{trait.system.type}}</td>
                        <td style="text-align: center;">{{trait.system.xpCost}}</td>
                        <td class="item-controls">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    {{!-- Infections (toxicants) --}}
    <div class="sla-panel" style="flex: 0 0 auto; max-height: 220px; margin-bottom: 5px; display: flex; flex-direction: column; min-height: 0;">
        <div class="sla-header-bar flexrow" style="align-items: center;">
            <span style="flex:1;">INFECTIONS</span>
            {{#if editable}}
            <div class="item-controls" style="float:none;">
                <a class="item-create" data-type="toxicant" title="Add toxicant"><i class="fas fa-plus"></i></a>
            </div>
            {{/if}}
        </div>
        <div class="scroll-list" style="flex:1; min-height:0; overflow-y:auto;">
            <table class="sla-table">
                <thead>
                    <tr>
                        <th style="text-align:left; padding-left:5px;" colspan="2">Name</th>
                        <th style="width:48px; text-align:center;">IR</th>
                        <th style="width:100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each infections as |item|}}
                    <tr class="item" data-item-id="{{item._id}}" style="border-bottom:1px solid #333;">
                        <td class="item-image" style="width:30px; padding:2px;">
                            <img src="{{item.img}}" width="24" height="24" alt="" />
                        </td>
                        <td class="item-name" style="padding-left:5px; font-weight:bold; color:#e0e0e0;">
                            <a class="rollable" data-roll-type="item">{{item.name}}</a>
                        </td>
                        <td style="text-align:center; color:#aaa;">{{item.system.infectionRating}}</td>
                        <td class="item-controls" style="text-align:right; padding-right:5px;">
                            <a class="item-control item-use-toxicant" title="Infection test"><i class="fas fa-biohazard" style="color:#9acd32; margin-right:5px;"></i></a>
                            <a class="item-edit" title="Edit Item"><i class="fas fa-edit" style="color:#444;"></i></a>
                            <a class="item-delete" title="Delete Item"><i class="fas fa-trash" style="color:#444;"></i></a>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="4" style="padding:12px; text-align:center; color:#555; font-style:italic;">No active infection entries. Drag a toxicant here or add one.</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    {{!-- Notes Section --}}
    <div class="sla-panel" style="flex: 1; min-height: 300px; display: flex; flex-direction: column;">
        <div class="sla-header-bar">NOTES</div>
        {{!-- Added class 'sla-editor-container' and forced height --}}
        <div class="sla-editor-container" style="flex: 1; height: 100%; border: none; padding: 5px; background: #000;">
            {{!-- {{editor}} is non-functional on Application V2 — use HTMLProseMirrorElement (Foundry #12989) --}}
            {{#if editable}}
            <prose-mirror class="editor" name="system.notes" toggled value="{{system.notes}}">{{{enrichedNotes}}}</prose-mirror>
            {{else}}
            <div class="editor notes-readonly">{{{enrichedNotes}}}</div>
            {{/if}}
        </div>
    </div>
</div>
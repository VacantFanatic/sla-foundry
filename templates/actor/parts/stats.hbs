                <span class="sla-stat-play-total"
                    style="font-size:1.35em;font-weight:bold;min-width:2rem;text-align:center;color:{{#if statInputs}}{{#if (lt system.stats.conc.total statInputs.conc)}}#ff5555{{else}}{{#if (gt system.stats.conc.total statInputs.conc)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{else}}{{#if (lt system.stats.conc.total system.stats.conc.value)}}#ff5555{{else}}{{#if (gt system.stats.conc.total system.stats.conc.value)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{/if}};">{{system.stats.conc.total}}</span>

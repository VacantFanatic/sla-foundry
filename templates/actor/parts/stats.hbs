<div class="stats-matrix">

    <div class="stat-col">
        <div class="rating-header">
            <span class="rating-label" title="{{localize 'SLA.ActorSheet.BodyRating'}}">BODY</span>
            <input type="number" class="rating-val" name="system.ratings.body.value" value="{{system.ratings.body.value}}" />
        </div>
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="str" label="STR" rollKey="SLA.ActorSheet.RollStatStr"}}
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="dex" label="DEX" rollKey="SLA.ActorSheet.RollStatDex"}}
    </div>

    <div class="stat-col">
        <div class="rating-header">
            <span class="rating-label" title="{{localize 'SLA.ActorSheet.BrainsRating'}}">BRAINS</span>
            <input type="number" class="rating-val" name="system.ratings.brains.value" value="{{system.ratings.brains.value}}" />
        </div>
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="know" label="KNOW" rollKey="SLA.ActorSheet.RollStatKnow"}}
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="conc" label="CONC" rollKey="SLA.ActorSheet.RollStatConc"}}
    </div>

    <div class="stat-col">
        <div class="rating-header">
            <span class="rating-label" title="{{localize 'SLA.ActorSheet.BravadoRating'}}">BRAVADO</span>
            <input type="number" class="rating-val" name="system.ratings.bravado.value" value="{{system.ratings.bravado.value}}" />
        </div>
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="cha" label="CHA" rollKey="SLA.ActorSheet.RollStatCha"}}
        {{> "systems/sla-industries/templates/actor/parts/stat-row.hbs" key="cool" label="COOL" rollKey="SLA.ActorSheet.RollStatCool"}}
    </div>

    <div class="side-col">
        {{#if (or system.stats.luck.max system.stats.luck.value)}}
        <div class="side-box">
            <label title="{{localize 'SLA.ActorSheet.Luck'}}">{{localize "SLA.ActorSheet.Luck"}}</label>
            <div class="flexrow">
                <input type="number" name="system.stats.luck.value" value="{{system.stats.luck.value}}" placeholder="0" />
                <span>/</span>
                <input type="number" name="system.stats.luck.max" value="{{system.stats.luck.max}}" placeholder="0" />
            </div>
        </div>
        {{/if}}

        {{#if (or system.stats.flux.max system.stats.flux.value)}}
        <div class="side-box">
            <label title="{{localize 'SLA.ActorSheet.Flux'}}">{{localize "SLA.ActorSheet.Flux"}}</label>
            <div class="flexrow">
                <input type="number" name="system.stats.flux.value" value="{{system.stats.flux.value}}" placeholder="0" />
                <span>/</span>
                <input type="number" name="system.stats.flux.max" value="{{system.stats.flux.max}}" placeholder="0" />
            </div>
        </div>
        {{/if}}

        <div class="side-box init rollable" data-roll-type="init" title="{{localize 'SLA.ActorSheet.RollInitiative'}}" aria-label="{{localize 'SLA.ActorSheet.RollInitiative'}}">
            <label>{{localize "SLA.ActorSheet.Initiative"}}</label>
            <div class="flexrow init-row">
                <span class="init-val">{{system.stats.init.value}}</span>
                <i class="fas fa-dice-d10" aria-hidden="true"></i>
            </div>
        </div>
    </div>

</div>

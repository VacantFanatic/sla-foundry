<div class="stats-matrix">

    {{!-- COLUMN 1: BODY (STR / DEX) --}}
    <div class="stat-col">
        <div class="rating-header">
            <span class="rating-label">BODY</span>
            <input type="number" class="rating-val" name="system.ratings.body.value"
                value="{{system.ratings.body.value}}" />
        </div>

        {{!-- STR --}}
        <div class="stat-box {{#if (eq statSheetMode "edit")}}sla-stat-box-mode-edit{{else}}sla-stat-box-mode-play{{/if}}">
            <label>STR</label>
            {{#if (eq statSheetMode "edit")}}
            <div class="flexrow sla-stat-row-inner" style="align-items:center; justify-content:center; gap:6px; flex-wrap:wrap;">
                {{#if (and owner editable)}}
                <input type="number" class="sla-stat-base-input-edit" name="system.stats.str.value"
                    value="{{#if statInputs}}{{statInputs.str}}{{else}}{{system.stats.str.value}}{{/if}}"
                    title="{{localize "SLA.StatSheetMode.BaseTooltip"}}" />
                {{else}}
                <span class="sla-stat-base-input-edit sla-stat-readonly">{{#if statInputs}}{{statInputs.str}}{{else}}{{system.stats.str.value}}{{/if}}</span>
                {{/if}}
                {{#if statInputs}}{{#if (ne system.stats.str.total statInputs.str)}}
                <span class="sla-stat-effective-hint" title="{{localize "SLA.StatSheetMode.EffectiveTooltip"}}">→ {{system.stats.str.total}}</span>
                {{/if}}{{/if}}
            </div>
            {{else}}
            <div class="flexrow sla-stat-row-inner" style="align-items:center; justify-content:center; gap:6px;">
                <input type="hidden" name="system.stats.str.value" value="{{#if statInputs}}{{statInputs.str}}{{else}}{{system.stats.str.value}}{{/if}}" />
                <span class="sla-stat-play-total"
                    style="font-size:1.35em;font-weight:bold;min-width:2rem;text-align:center;color:{{#if statInputs}}{{#if (lt system.stats.str.total statInputs.str)}}#ff5555{{else}}{{#if (gt system.stats.str.total statInputs.str)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{else}}{{#if (lt system.stats.str.total system.stats.str.value)}}#ff5555{{else}}{{#if (gt system.stats.str.total system.stats.str.value)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{/if}};">{{system.stats.str.total}}</span>
                <span class="sla-stat-play-base-label" title="{{localize "SLA.StatSheetMode.BaseInPlayTooltip"}}">({{#if statInputs}}{{statInputs.str}}{{else}}{{system.stats.str.value}}{{/if}})</span>
            </div>
            {{/if}}
            <a class="rollable" data-roll-type="stat" data-key="str"><i class="fas fa-dice-d20"></i></a>
        </div>

        {{!-- DEX --}}
        <div class="stat-box {{#if (eq statSheetMode "edit")}}sla-stat-box-mode-edit{{else}}sla-stat-box-mode-play{{/if}}">
            <label>DEX</label>
            {{#if (eq statSheetMode "edit")}}
            <div class="flexrow sla-stat-row-inner" style="align-items:center; justify-content:center; gap:6px; flex-wrap:wrap;">
                {{#if (and owner editable)}}
                <input type="number" class="sla-stat-base-input-edit" name="system.stats.dex.value"
                    value="{{#if statInputs}}{{statInputs.dex}}{{else}}{{system.stats.dex.value}}{{/if}}"
                    title="{{localize "SLA.StatSheetMode.BaseTooltip"}}" />
                {{else}}
                <span class="sla-stat-base-input-edit sla-stat-readonly">{{#if statInputs}}{{statInputs.dex}}{{else}}{{system.stats.dex.value}}{{/if}}</span>
                {{/if}}
                {{#if statInputs}}{{#if (ne system.stats.dex.total statInputs.dex)}}
                <span class="sla-stat-effective-hint" title="{{localize "SLA.StatSheetMode.EffectiveTooltip"}}">→ {{system.stats.dex.total}}</span>
                {{/if}}{{/if}}
            </div>
            {{else}}
            <div class="flexrow sla-stat-row-inner" style="align-items:center; justify-content:center; gap:6px;">
                <input type="hidden" name="system.stats.dex.value" value="{{#if statInputs}}{{statInputs.dex}}{{else}}{{system.stats.dex.value}}{{/if}}" />
                <span class="sla-stat-play-total"
                    style="font-size:1.35em;font-weight:bold;min-width:2rem;text-align:center;color:{{#if statInputs}}{{#if (lt system.stats.dex.total statInputs.dex)}}#ff5555{{else}}{{#if (gt system.stats.dex.total statInputs.dex)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{else}}{{#if (lt system.stats.dex.total system.stats.dex.value)}}#ff5555{{else}}{{#if (gt system.stats.dex.total system.stats.dex.value)}}#39ff14{{else}}#eee{{/if}}{{/if}}{{/if}};">{{system.stats.dex.total}}</span>
                <span class="sla-stat-play-base-label" title="{{localize "SLA.StatSheetMode.BaseInPlayTooltip"}}">({{#if statInputs}}{{statInputs.dex}}{{else}}{{system.stats.dex.value}}{{/if}})</span>
            </div>
            {{/if}}
            <a class="rollable" data-roll-type="stat" data-key="dex"><i class="fas fa-dice-d20"></i></a>
        </div>
    </div>


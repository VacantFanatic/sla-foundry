    {{!-- COLUMN 4: SIDE STATS --}}
    <div class="side-col">
        {{#if (or system.stats.luck.max system.stats.luck.value)}}
        <div class="side-box">
            <label>LUCK</label>
            <div class="flexrow">
                <input type="number" name="system.stats.luck.value" value="{{system.stats.luck.value}}"
                    placeholder="0" />
                <span>/</span>
                <input type="number" name="system.stats.luck.max" value="{{system.stats.luck.max}}" placeholder="0" />
            </div>
        </div>
        {{/if}}

        {{#if (or system.stats.flux.max system.stats.flux.value)}}
        <div class="side-box">
            <label>FLUX</label>
            <div class="flexrow">
                <input type="number" name="system.stats.flux.value" value="{{system.stats.flux.value}}"
                    placeholder="0" />
                <span>/</span>
                <input type="number" name="system.stats.flux.max" value="{{system.stats.flux.max}}" placeholder="0" />
            </div>
        </div>
        {{/if}}

        <div class="side-box init rollable" data-roll-type="init" style="cursor:pointer;" title="Roll Initiative">
            <label style="cursor:pointer;">INIT</label>
            <div class="flexrow" style="justify-content:center; align-items:center;">
                <span class="init-val">{{system.stats.init.value}}</span>
                <i class="fas fa-dice-d10" style="margin-left:5px;"></i>
            </div>
        </div>
    </div>

</div>

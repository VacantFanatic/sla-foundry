<div class="sla-panel sla-ebb-formulas-panel" style="border-color: #8a2be2;">
    <div class="sla-header-bar" style="background: #3a003a; border-color: #8a2be2;">{{localize "SLA.EbbFormulasListHeader"}}</div>

    <div class="scroll-list sla-ebb-formulas-scroll">
        {{#each ebbFormulas as |item id|}}
        <div class="sla-ebb-formula-card item" data-item-id="{{item._id}}">
            <div class="sla-ebb-formula-card__row">
                <span class="item-name sla-ebb-formula-card__name" style="cursor: pointer;" title="{{localize "SLA.EbbDisciplineTitle"}}: {{item.system.discipline}}">
                    <i class="fas fa-magic sla-ebb-formula-card__icon"></i>
                    <span class="rollable" data-roll-type="item">{{item.name}}</span>
                </span>
                <span class="sla-ebb-formula-card__badges">
                    <span class="sla-ebb-badge sla-ebb-badge--target">{{item.ebbTargetLabel}}</span>
                    <span class="sla-ebb-badge sla-ebb-badge--effect">{{item.ebbEffectLabel}}</span>
                    {{#if (gt item.system.removeWounds 0)}}
                    <span class="sla-ebb-badge sla-ebb-badge--wounds">{{item.system.removeWounds}} {{localize "SLA.EbbWoundsShort"}}</span>
                    {{/if}}
                </span>
                <span class="sla-ebb-formula-card__cost">{{item.system.cost}} {{localize "SLA.EbbFluxShort"}}</span>
                <span class="item-controls sla-ebb-formula-card__controls">
                    <a class="item-edit" title="{{localize "SLA.EditFormula"}}"><i class="fas fa-edit"></i></a>
                    <a class="item-delete" title="{{localize "SLA.DeleteFormula"}}"><i class="fas fa-trash"></i></a>
                </span>
            </div>
        </div>
        {{/each}}
        {{#unless ebbFormulas.length}}
        <div class="sla-ebb-empty">{{localize "SLA.NoEbbFormulas"}}</div>
        {{/unless}}
    </div>
</div>

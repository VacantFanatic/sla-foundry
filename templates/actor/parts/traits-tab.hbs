<div class="flexcol full-height">
    <div class="sla-panel sla-traits-panel">
        <div class="sla-header-bar flexrow">
            <span class="open-compendium" data-compendium="sla-industries.traits"
                title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.Traits"}}</span>
        </div>
        <div class="scroll-list">
            <table class="sla-table">
                <thead>
                    <tr>
                        <th>{{localize "SLA.ActorSheet.ColName"}}</th>
                        <th class="sla-col-rank">{{localize "SLA.ActorSheet.ColRank"}}</th>
                        <th class="sla-col-type">{{localize "SLA.ItemSheet.Trait.Type"}}</th>
                        <th class="sla-col-cost">{{localize "SLA.ItemSheet.Trait.XpCost"}}</th>
                        <th class="sla-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each traits as |trait|}}
                    <tr class="item" data-item-id="{{trait._id}}">
                        <td class="item-name rollable" data-roll-type="item">{{trait.name}}</td>
                        <td class="sla-col-rank">{{trait.system.rank}}</td>
                        <td class="sla-col-type">{{trait.system.type}}</td>
                        <td class="sla-col-cost">{{trait.system.xpCost}}</td>
                        <td class="item-controls sla-col-actions">
                            <a class="item-edit" title="{{localize 'SLA.ActorSheet.EditItem'}}" aria-label="{{localize 'SLA.ActorSheet.EditItem'}}"><i class="fas fa-edit"></i></a>
                            <a class="item-delete" title="{{localize 'SLA.ActorSheet.DeleteItem'}}" aria-label="{{localize 'SLA.ActorSheet.DeleteItem'}}"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    {{else}}
                    <tr class="sla-table-empty">
                        <td colspan="5">{{localize "SLA.ActorSheet.TraitsEmpty"}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="sla-panel sla-infections-panel">
        <div class="sla-header-bar flexrow">
            <span>{{localize "SLA.ActorSheet.Infections"}}</span>
            {{#if editable}}
            <a class="item-create" data-type="toxicant" title="{{localize 'SLA.ActorSheet.CreateItem'}}" aria-label="{{localize 'SLA.ActorSheet.CreateItem'}}"><i class="fas fa-plus"></i></a>
            {{/if}}
        </div>
        <div class="scroll-list">
            <table class="sla-table">
                <thead>
                    <tr>
                        <th colspan="2">{{localize "SLA.ActorSheet.ColName"}}</th>
                        <th class="sla-col-rank">IR</th>
                        <th class="sla-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each infections as |item|}}
                    <tr class="item" data-item-id="{{item._id}}">
                        <td class="item-image sla-col-image">
                            <img src="{{item.img}}" width="24" height="24" alt="" />
                        </td>
                        <td class="item-name rollable" data-roll-type="item">{{item.name}}</td>
                        <td class="sla-col-rank">{{item.system.infectionRating}}</td>
                        <td class="item-controls sla-col-actions">
                            <a class="item-control item-use-toxicant" title="{{localize 'SLA.ActorSheet.InfectionTest'}}" aria-label="{{localize 'SLA.ActorSheet.InfectionTest'}}"><i class="fas fa-biohazard"></i></a>
                            <a class="item-edit" title="{{localize 'SLA.ActorSheet.EditItem'}}" aria-label="{{localize 'SLA.ActorSheet.EditItem'}}"><i class="fas fa-edit"></i></a>
                            <a class="item-delete" title="{{localize 'SLA.ActorSheet.DeleteItem'}}" aria-label="{{localize 'SLA.ActorSheet.DeleteItem'}}"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    {{else}}
                    <tr class="sla-table-empty">
                        <td colspan="4">{{localize "SLA.ActorSheet.InfectionsEmpty"}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>

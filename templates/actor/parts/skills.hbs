<div class="sla-panel full-height">
    <div class="sla-header-bar flexrow">
        <span class="open-compendium" data-compendium="sla-industries.skills"
            title="{{localize 'SLA.ActorSheet.OpenCompendium'}}">{{localize "SLA.ActorSheet.Skills"}}</span>
    </div>

    <div class="scroll-list">
        <table class="sla-table">
            <thead>
                <tr>
                    <th>{{localize "SLA.ActorSheet.ColName"}}</th>
                    <th class="sla-col-rank">{{localize "SLA.ActorSheet.ColRank"}}</th>
                    <th class="sla-col-roll">{{localize "SLA.ActorSheet.ColRoll"}}</th>
                    <th class="sla-col-actions"></th>
                </tr>
            </thead>
            <tbody>
                {{#each skillsByStat as |group key|}}
                {{#if group.items.length}}
                <tr class="skill-group-header">
                    <td colspan="4">{{group.label}}</td>
                </tr>
                {{#each group.items as |skill|}}
                <tr class="item" data-item-id="{{skill._id}}">
                    <td class="item-name rollable" data-roll-type="item">{{skill.name}}</td>
                    <td class="sla-col-rank">{{skill.system.rank}}</td>
                    <td class="sla-col-roll">
                        <a class="rollable" data-roll-type="skill" title="{{localize 'SLA.ActorSheet.RollSkill'}}" aria-label="{{localize 'SLA.ActorSheet.RollSkill'}}: {{skill.name}}"><i class="fas fa-dice-d20" aria-hidden="true"></i></a>
                    </td>
                    <td class="item-controls sla-col-actions">
                        <a class="item-edit" title="{{localize 'SLA.ActorSheet.EditSkill'}}" aria-label="{{localize 'SLA.ActorSheet.EditSkill'}}"><i class="fas fa-edit"></i></a>
                        <a class="item-delete" title="{{localize 'SLA.ActorSheet.DeleteSkill'}}" aria-label="{{localize 'SLA.ActorSheet.DeleteSkill'}}"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
                {{/each}}
                {{/if}}
                {{/each}}
                {{#unless (or skillsByStat.str.items.length skillsByStat.dex.items.length skillsByStat.know.items.length skillsByStat.conc.items.length skillsByStat.cha.items.length skillsByStat.cool.items.length)}}
                <tr class="sla-table-empty">
                    <td colspan="4">{{localize "SLA.ActorSheet.SkillsEmpty"}}</td>
                </tr>
                {{/unless}}
            </tbody>
        </table>
    </div>
</div>

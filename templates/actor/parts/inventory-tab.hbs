<div class="sla-panel full-height">
    <div class="sla-header-bar flexrow">
        <span>{{localize "SLA.ActorSheet.Inventory"}}</span>
        <a class="item-create" data-type="item" title="{{localize 'SLA.ActorSheet.CreateItem'}}" aria-label="{{localize 'SLA.ActorSheet.CreateItem'}}"><i class="fas fa-plus"></i></a>
    </div>
    <p class="sla-section-hint">{{localize "SLA.ActorSheet.InventoryHint"}}</p>

    <div class="scroll-list">
        <table class="sla-table">
            {{#each inventory as |section key|}}
            {{#if section.items.length}}
                <thead>
                    <tr>
                        <th colspan="2">{{section.label}}</th>
                        <th class="sla-col-qty">Qty</th>
                        <th class="sla-col-wt">Wt.</th>
                        <th class="sla-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each section.items as |item|}}
                    <tr class="item" data-item-id="{{item._id}}">
                        <td class="item-image sla-col-image">
                            <img src="{{item.img}}" width="24" height="24" alt="" />
                        </td>
                        <td class="item-name">
                            <a class="rollable" data-roll-type="item">{{item.name}}</a>
                            {{#if item.system.equipped}}
                            <span class="sla-inventory-equipped-badge">{{localize "SLA.ActorSheet.InventoryEquipped"}}</span>
                            {{/if}}
                        </td>
                        <td class="sla-col-qty">{{item.system.quantity}}</td>
                        <td class="sla-col-wt">{{item.system.weight}}</td>
                        <td class="item-controls sla-col-actions">
                            {{#if (or (eq item.type "weapon") (eq item.type "armor"))}}
                            <a class="item-toggle" title="{{#if item.system.equipped}}{{localize 'SLA.ActorSheet.HolsterItem'}}{{else}}{{localize 'SLA.ActorSheet.EquipItem'}}{{/if}}" aria-label="{{#if item.system.equipped}}{{localize 'SLA.ActorSheet.HolsterItem'}}{{else}}{{localize 'SLA.ActorSheet.EquipItem'}}{{/if}}">
                                {{#if item.system.equipped}}<i class="fas fa-check-circle sla-combat-equipped"></i>{{else}}<i class="fas fa-circle sla-combat-unequipped"></i>{{/if}}
                            </a>
                            {{/if}}
                            {{#if (eq item.type "drug")}}
                            <a class="item-control item-use-drug" title="{{localize 'SLA.ActorSheet.ConsumeDrug'}}" aria-label="{{localize 'SLA.ActorSheet.ConsumeDrug'}}"><i class="fas fa-syringe"></i></a>
                            {{/if}}
                            <a class="item-edit" title="{{localize 'SLA.ActorSheet.EditItem'}}" aria-label="{{localize 'SLA.ActorSheet.EditItem'}}"><i class="fas fa-edit"></i></a>
                            <a class="item-delete" title="{{localize 'SLA.ActorSheet.DeleteItem'}}" aria-label="{{localize 'SLA.ActorSheet.DeleteItem'}}"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            {{/if}}
            {{/each}}
        </table>

        {{#unless (or inventory.weapon.items.length (or inventory.armor.items.length (or inventory.item.items.length (or inventory.drug.items.length inventory.magazine.items.length))))}}
        <div class="sla-empty-state">{{localize "SLA.ActorSheet.InventoryEmpty"}}</div>
        {{/unless}}
    </div>
</div>

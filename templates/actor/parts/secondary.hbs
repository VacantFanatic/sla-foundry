<div class="flexcol">

    <div class="sla-box sla-move-box {{#if (eq statSheetMode "edit")}}sla-move-box-mode-edit{{else}}sla-move-box-mode-play{{/if}}">
        <div class="sla-box-header">{{localize "SLA.ActorSheet.Movement"}}</div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.ClosingSpeed'}}">{{localize "SLA.ActorSheet.ClosingSpeed"}}</label>
            {{#if (eq statSheetMode "edit")}}
            <input type="number" name="system.move.closing" value="{{system.move.closing}}" class="sla-input-mini"/>
            {{else}}
            <div class="sla-move-play-cell">
                <input type="hidden" name="system.move.closing" value="{{system.move.closing}}" />
                <span class="sla-move-play-val">{{system.move.closing}}</span>
            </div>
            {{/if}}
        </div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.RushingSpeed'}}">{{localize "SLA.ActorSheet.RushingSpeed"}}</label>
            {{#if (eq statSheetMode "edit")}}
            <input type="number" name="system.move.rushing" value="{{system.move.rushing}}" class="sla-input-mini"/>
            {{else}}
            <div class="sla-move-play-cell">
                <input type="hidden" name="system.move.rushing" value="{{system.move.rushing}}" />
                <span class="sla-move-play-val">{{system.move.rushing}}</span>
            </div>
            {{/if}}
        </div>
    </div>

    <div class="sla-box {{#if hpBar.isCriticalHp}}sla-hp-bar is-critical-hp{{/if}}">
        <div class="sla-box-header">{{localize "SLA.ActorSheet.Vitals"}}</div>
        <div class="sla-hp-bar">
            <div class="sla-hp-bar__track" role="presentation">
                <div class="sla-hp-bar__fill is-{{hpBar.tone}}" style="width: {{hpBar.percent}}%;"></div>
            </div>
        </div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.HitPoints'}}">{{localize "SLA.ActorSheet.HitPoints"}}</label>
            <div class="flexrow sla-hp-inputs">
                <input type="number" name="system.hp.value" value="{{system.hp.value}}" class="sla-input-mini"/>
                <span class="sla-hp-sep">/</span>
                <input type="number" name="system.hp.max" value="{{system.hp.max}}" class="sla-input-mini" readonly />
            </div>
        </div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.ArmorPV'}}">{{localize "SLA.ActorSheet.ArmorPV"}}</label>
            <input type="number" name="system.armor.pv" value="{{system.armor.pv}}" class="sla-input-mini sla-armor-pv" readonly />
        </div>
    </div>

    <div class="sla-box {{encumbranceClass}}">
        <div class="sla-box-header">{{localize "SLA.ActorSheet.Status"}}</div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.Encumbrance'}}">{{localize "SLA.ActorSheet.Encumbrance"}}</label>
            <div class="flexrow sla-enc-inputs">
                <input type="number" name="system.encumbrance.value" value="{{system.encumbrance.value}}" class="sla-input-mini"/>
                <span class="sla-hp-sep">/</span>
                <input type="number" name="system.encumbrance.max" value="{{system.encumbrance.max}}" class="sla-input-mini" readonly />
            </div>
        </div>
        <div class="compact-row">
            <label title="{{localize 'SLA.ActorSheet.Experience'}}">{{localize "SLA.ActorSheet.Experience"}}</label>
            <div class="flexrow sla-xp-row">
                <input type="number" name="system.xp.value" value="{{system.xp.value}}" class="sla-input-mini" readonly />
                <button type="button" class="xp-button sla-xp-button" title="{{localize 'SLA.ActorSheet.ManageXP'}}" aria-label="{{localize 'SLA.ActorSheet.ManageXP'}}">
                    <i class="fas fa-coins" aria-hidden="true"></i>
                    <span>{{localize "SLA.ActorSheet.ManageXP"}}</span>
                </button>
            </div>
        </div>
    </div>

</div>

<div class="sla-panel sla-combat-loadout">
    <div class="sla-header-bar">COMBAT LOADOUT</div>
    <div class="scroll-list">

        {{!-- 1. WEAPONS GROUP --}}
        {{#if weapons.length}}
        <div class="group-header sla-combat-group-header">
            WEAPONS
        </div>
        <div class="combat-list">
            <div class="sla-combat-colhead" role="presentation">
                <div class="sla-combat-colhead-name">Item</div>
                <div class="sla-combat-colhead-dmg">Damage</div>
                <div class="sla-combat-colhead-extra">Ammo / Qty</div>
                <div class="sla-combat-colhead-actions"></div>
            </div>
            {{#each weapons as |item|}}
            <div class="item sla-combat-row" data-item-id="{{item._id}}">

                <div class="sla-combat-name item-name">
                    <a class="item-edit">{{item.name}}</a>
                </div>

                <div class="sla-combat-stat-dmg" title="Damage: {{item.system.damage}}">
                    <span>{{item.resolvedDamage}}</span>
                </div>

                <div class="sla-combat-stat-extra">
                    {{#if (eq item.system.attackType "ranged")}}
                    {{#if item.system.maxAmmo}}
                    <span class="sla-stat-readout sla-combat-ammo {{#if (eq item.system.ammo 0)}}is-empty{{/if}}">
                        [{{item.system.ammo}}/{{item.system.maxAmmo}}]
                    </span>
                    {{/if}}
                    {{/if}}

                    {{#if (eq item.type "explosive")}}
                    <span class="sla-stat-readout sla-combat-qty {{#if (eq item.system.quantity 0)}}is-empty{{/if}}">
                        x{{item.system.quantity}}
                    </span>
                    {{/if}}
                </div>

                <div class="item-controls sla-combat-actions">
                    <a class="rollable sla-combat-action" data-roll-type="item" title="Attack">
                        <i class="fas fa-crosshairs"></i>
                    </a>

                    <a class="item-roll-damage sla-combat-action" title="Roll damage">
                        <i class="fas fa-droplet"></i>
                    </a>

                    {{!-- Ranged only: melee / unarmed never show load or reload --}}
                    {{#if (and item.isReloadable (eq item.system.attackType "ranged"))}}
                    <a class="item-reload sla-combat-action" title="{{#if (lte item.system.ammo 0)}}Load{{else}}Reload{{/if}}">
                        {{#if (lte item.system.ammo 0)}}
                        <i class="fas fa-dot-circle sla-combat-reload-empty"></i>
                        {{else}}
                        <i class="fas fa-sync-alt sla-combat-reload-ready"></i>
                        {{/if}}
                    </a>
                    {{else}}
                    <span class="sla-combat-action-spacer" aria-hidden="true"></span>
                    {{/if}}

                    <a class="item-toggle sla-combat-action" title="Equip/Holster">
                        {{#if item.system.equipped}}
                        <i class="fas fa-check-circle sla-combat-equipped"></i>
                        {{else}}
                        <i class="fas fa-circle sla-combat-unequipped"></i>
                        {{/if}}
                    </a>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

        {{!-- 2. ARMOR GROUP --}}
        {{#if armors.length}}
        <div class="group-header sla-combat-group-header sla-combat-group-header--armor">
            ARMOR
        </div>
        <div class="combat-list">
            <div class="sla-combat-colhead" role="presentation">
                <div class="sla-combat-colhead-name">Item</div>
                <div class="sla-combat-colhead-dmg">PV</div>
                <div class="sla-combat-colhead-extra">Resistance</div>
                <div class="sla-combat-colhead-actions"></div>
            </div>
            {{#each armors as |item|}}
            <div class="item sla-combat-row" data-item-id="{{item._id}}">

                <div class="sla-combat-name item-name">
                    <a class="item-edit">{{item.name}}</a>
                </div>

                <div class="sla-combat-stat-dmg">
                    <span>PV: {{item.system.pv}}</span>
                </div>

                <div class="sla-combat-stat-extra">
                    <div class="sla-combat-resistance">
                        <i class="fas fa-shield-alt sla-combat-resistance-icon"></i>
                        <input type="number" class="inline-edit sla-combat-resistance-input" data-field="system.resistance.value"
                            data-item-id="{{item._id}}" value="{{item.system.resistance.value}}" />
                        <span class="sla-combat-resistance-max">/ {{item.system.resistance.max}}</span>
                    </div>
                </div>

                <div class="item-controls sla-combat-actions">
                    <span class="sla-combat-action-spacer" aria-hidden="true"></span>
                    <span class="sla-combat-action-spacer" aria-hidden="true"></span>
                    <span class="sla-combat-action-spacer" aria-hidden="true"></span>
                    <a class="item-toggle sla-combat-action" title="Wear/Remove">
                        {{#if item.system.equipped}}
                        <i class="fas fa-check-circle sla-combat-equipped"></i>
                        {{else}}
                        <i class="fas fa-circle sla-combat-unequipped"></i>
                        {{/if}}
                    </a>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}

    </div>
</div>
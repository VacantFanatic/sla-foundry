<div class="{{cssClass}} sla-sheet threat-sheet standard-form sla-vehicle-layout" autocomplete="off">
    <div class="threat-header">
        <div class="threat-header-row">
            <img class="threat-logo" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="{{actor.name}}" />
            <div class="header-name">
                <input name="name" type="text" value="{{actor.name}}" placeholder="Vehicle Name" />
            </div>
        </div>
    </div>

    <div class="threat-body sla-vehicle-body">
        <div class="threat-derived sla-vehicle-stats">
            <div class="threat-box">
                <label>{{localize "SLA.ActorSheet.HitPoints"}}</label>
                <div class="flexrow">
                    <input type="number" name="system.hp.value" value="{{system.hp.value}}" />
                    <span>/</span>
                    <input type="number" name="system.hp.max" value="{{system.hp.max}}" />
                </div>
            </div>
            <div class="threat-box">
                <label>{{localize "SLA.ActorSheet.ArmorPV"}}</label>
                <input type="number" name="system.armor.pv" value="{{system.armor.pv}}" placeholder="0" />
            </div>
            <div class="threat-box">
                <label>RESIST</label>
                <div class="flexrow">
                    <input type="number" name="system.armor.resist.value" value="{{system.armor.resist.value}}" />
                    <span>/</span>
                    <input type="number" name="system.armor.resist.max" value="{{system.armor.resist.max}}" />
                </div>
            </div>
            <div class="threat-box">
                <label>{{localize "SLA.ActorSheet.Movement"}}</label>
                <input type="number" name="system.move.value" value="{{system.move.value}}" />
            </div>
            <div class="threat-box">
                <label>DRIVE SKILL</label>
                <input type="text" name="system.skill" value="{{system.skill}}" />
            </div>
        </div>

        <div class="threat-section-bar">WEAPONS</div>
        <div class="threat-content-box sla-vehicle-weapons">
            <div class="vehicle-weapon-drop sla-drop">{{localize "SLA.ActorSheet.VehicleDropWeapon"}}</div>
            {{#unless weapons.length}}
            <div class="sla-empty-state">{{localize "SLA.ActorSheet.VehicleWeaponsEmpty"}}</div>
            {{/unless}}

            {{#each weapons as |item|}}
            <div class="item threat-item flexrow" data-item-id="{{item._id}}">
                <span class="item-name rollable" data-roll-type="item">{{item.name}}</span>
                <span class="sla-vehicle-dmg" title="Damage: {{item.system.damage}}">
                    (Dmg: {{item.resolvedDamage}})
                </span>
                <div class="item-controls">
                    <a class="item-edit" title="{{localize 'SLA.ActorSheet.EditItem'}}" aria-label="{{localize 'SLA.ActorSheet.EditItem'}}"><i class="fas fa-edit"></i></a>
                    <a class="item-delete" title="{{localize 'SLA.ActorSheet.DeleteItem'}}" aria-label="{{localize 'SLA.ActorSheet.DeleteItem'}}"><i class="fas fa-trash"></i></a>
                </div>
            </div>
            {{/each}}
        </div>

        <div class="threat-section-bar">DIMENSIONS</div>
        <div class="threat-content-box sla-vehicle-dimensions">
            <div class="flexrow sla-vehicle-dim-row">
                <div class="sla-field">
                    <label>Length</label>
                    <input type="text" name="system.dimensions.length" value="{{system.dimensions.length}}" />
                </div>
                <div class="sla-field">
                    <label>Width</label>
                    <input type="text" name="system.dimensions.width" value="{{system.dimensions.width}}" />
                </div>
                <div class="sla-field">
                    <label>Height</label>
                    <input type="text" name="system.dimensions.height" value="{{system.dimensions.height}}" />
                </div>
            </div>
            <div class="sla-field">
                <label>Capacity</label>
                <input type="text" name="system.capacity" value="{{system.capacity}}" placeholder="e.g. 1 driver, 1 passenger" />
            </div>
        </div>

        <div class="threat-section-bar">VEHICLE COMBAT RULES</div>
        <div class="threat-content-box">
            <div class="flexrow sla-vehicle-rules">
                <label class="sla-field sla-field--toggle">
                    <span>Provides Cover</span>
                    <input type="checkbox" name="system.providesCombatCover" {{checked system.providesCombatCover}} />
                </label>
                <label class="sla-field sla-field--toggle">
                    <span>Mounted Weapons Ignore Skill Requirement</span>
                    <input type="checkbox" name="system.mountedWeaponsIgnoreSkillReq" {{checked system.mountedWeaponsIgnoreSkillReq}} />
                </label>
            </div>
        </div>

        <div class="threat-section-bar">{{localize "SLA.ActorSheet.Notes"}}</div>
        <div class="threat-content-box threat-notes-editor">
            {{#if editable}}
            <prose-mirror class="editor" name="system.notes" toggled value="{{system.notes}}">{{{enrichedNotes}}}</prose-mirror>
            {{else}}
            <div class="editor">{{{enrichedNotes}}}</div>
            {{/if}}
        </div>
    </div>
</div>

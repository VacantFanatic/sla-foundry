<div class="{{cssClass}} sla-sheet threat-sheet standard-form sla-actor-layout" autocomplete="off">

    {{!-- THREAT HEADER --}}
    <div class="threat-header">
        <div style="display:flex; align-items:center; flex:1;">
            <img class="threat-logo" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
            <div class="header-name" style="flex:1;">
                <input name="name" type="text" value="{{actor.name}}" placeholder="Threat Name" />
            </div>
        </div>
        {{!-- Optional: Faction or other info could go here --}}
    </div>

    {{!-- STATS BLOCK --}}
    <div class="threat-body" style="padding: 5px;">
        <table class="threat-table">
            <thead>
                <tr class="threat-row-label">
                    <th>STR <a class="rollable" data-roll-type="stat" data-key="str" data-label="Strength"><i
                                class="fas fa-dice-d10"></i></a></th>
                    <th>DEX <a class="rollable" data-roll-type="stat" data-key="dex" data-label="Dexterity"><i
                                class="fas fa-dice-d10"></i></a></th>
                    <th>KNOW <a class="rollable" data-roll-type="stat" data-key="know" data-label="Knowledge"><i
                                class="fas fa-dice-d10"></i></a></th>
                    <th>CONC <a class="rollable" data-roll-type="stat" data-key="conc" data-label="Concentration"><i
                                class="fas fa-dice-d10"></i></a></th>
                    <th>CHA <a class="rollable" data-roll-type="stat" data-key="cha" data-label="Charisma"><i
                                class="fas fa-dice-d10"></i></a></th>
                    <th>COOL <a class="rollable" data-roll-type="stat" data-key="cool" data-label="Cool"><i
                                class="fas fa-dice-d10"></i></a></th>
                </tr>
            </thead>
            <tbody>
                <tr class="threat-row-value">
                    <td><input type="number" name="system.stats.str.value" value="{{#if statInputs}}{{statInputs.str}}{{else}}{{system.stats.str.value}}{{/if}}" /></td>
                    <td><input type="number" name="system.stats.dex.value" value="{{#if statInputs}}{{statInputs.dex}}{{else}}{{system.stats.dex.value}}{{/if}}" /></td>
                    <td><input type="number" name="system.stats.know.value" value="{{#if statInputs}}{{statInputs.know}}{{else}}{{system.stats.know.value}}{{/if}}" /></td>
                    <td><input type="number" name="system.stats.conc.value" value="{{#if statInputs}}{{statInputs.conc}}{{else}}{{system.stats.conc.value}}{{/if}}" /></td>
                    <td><input type="number" name="system.stats.cha.value" value="{{#if statInputs}}{{statInputs.cha}}{{else}}{{system.stats.cha.value}}{{/if}}" /></td>
                    <td><input type="number" name="system.stats.cool.value" value="{{#if statInputs}}{{statInputs.cool}}{{else}}{{system.stats.cool.value}}{{/if}}" /></td>
                </tr>
            </tbody>
        </table>

        {{!-- DERIVED STATS --}}
        <div class="threat-derived">
            <div class="threat-box">
                <label>INIT</label>
                <div class="flexrow">
                    {{!-- FIX: Changed from Span to Input --}}
                    <input type="number" name="system.stats.init.value" value="{{system.stats.init.value}}"
                        style="font-weight:bold; font-size:1.2em; border:none; background:transparent; text-align:center; width: 50px;" />
                    <a class="rollable" data-roll-type="init"><i class="fas fa-dice-d10"></i></a>
                </div>
            </div>
            <div class="threat-box">
                <label>MOVE (Close/Rush)</label>
                <div class="flexrow">
                    <input type="number" name="system.move.closing" value="{{system.move.closing}}" placeholder="0" />
                    <span>/</span>
                    <input type="number" name="system.move.rushing" value="{{system.move.rushing}}" placeholder="0" />
                </div>
            </div>
            {{#if (or system.stats.luck.max system.stats.luck.value)}}
            <div class="threat-box">
                <label>LUCK</label>
                <div class="flexrow">
                    <input type="number" name="system.stats.luck.value" value="{{system.stats.luck.value}}"
                        placeholder="0" />
                    <span>/</span>
                    <input type="number" name="system.stats.luck.max" value="{{system.stats.luck.max}}"
                        placeholder="0" />
                </div>
            </div>
            {{/if}}

            {{#if (or system.stats.flux.max system.stats.flux.value)}}
            <div class="threat-box">
                <label>FLUX</label>
                <div class="flexrow">
                    <input type="number" name="system.stats.flux.value" value="{{system.stats.flux.value}}"
                        placeholder="0" />
                    <span>/</span>
                    <input type="number" name="system.stats.flux.max" value="{{system.stats.flux.max}}"
                        placeholder="0" />
                </div>
            </div>
            {{/if}}
        </div>

        <div class="sla-actor-tabbed-area threat-tabbed-area">
            <section class="sheet-body sla-actor-sheet-body">
                <div class="tab {{tabs.combat.cssClass}}" data-group="primary" data-tab="combat" role="tabpanel" id="sla-npc-tabpanel-combat" aria-labelledby="sla-npc-tab-combat">
                    {{!-- Wounds / Conditions --}}
                    {{> "systems/sla-industries/templates/actor/parts/wounds.hbs"}}

                    {{!-- Combat loadout (operative-style aligned columns) --}}
                    {{> "systems/sla-industries/templates/actor/parts/combat-loadout.hbs"}}
                </div>

                <div class="tab {{tabs.skills.cssClass}}" data-group="primary" data-tab="skills" role="tabpanel" id="sla-npc-tabpanel-skills" aria-labelledby="sla-npc-tab-skills">
                    <div class="threat-content-box sla-skills-threat">
                        {{> "systems/sla-industries/templates/actor/parts/skills.hbs"}}
                    </div>
                </div>

                <div class="tab {{tabs.notes.cssClass}}" data-group="primary" data-tab="notes">
                    <div class="threat-section-bar">NOTES</div>
                    <div class="threat-content-box threat-notes-editor">
                        {{#if editable}}
                        <prose-mirror class="editor" name="system.notes" toggled value="{{system.notes}}">{{{enrichedNotes}}}</prose-mirror>
                        {{else}}
                        <div class="editor">{{{enrichedNotes}}}</div>
                        {{/if}}
                    </div>
                </div>

                <div class="tab {{tabs.inventory.cssClass}}" data-group="primary" data-tab="inventory">
                    {{> "systems/sla-industries/templates/actor/parts/inventory-tab.hbs"}}
                </div>

                <div class="tab {{tabs.effects.cssClass}}" data-group="primary" data-tab="effects">
                    {{> "systems/sla-industries/templates/actor/parts/effects-tab.hbs"}}
                </div>
            </section>

            <nav class="sheet-tabs tabs sla-sheet-tab-rail" data-group="primary" role="tablist" aria-label="{{localize 'SLA.ActorSheet.TabNavLabel'}}">
                <a class="item sla-tab-rail-btn {{tabs.combat.cssClass}}" href="#" id="sla-npc-tab-combat" role="tab" data-group="primary" data-tab="combat"
                    title="{{tabs.combat.label}}" aria-label="{{tabs.combat.label}}" aria-controls="sla-npc-tabpanel-combat">
                    <i class="fas {{tabs.combat.icon}}" aria-hidden="true"></i>
                    <span class="sla-tab-rail-tooltip">{{tabs.combat.label}}</span>
                </a>
                <a class="item sla-tab-rail-btn {{tabs.inventory.cssClass}}" href="#" data-group="primary" data-tab="inventory"
                    title="{{tabs.inventory.label}}">
                    <i class="fas {{tabs.inventory.icon}}"></i>
                    <span class="sla-tab-rail-tooltip">{{tabs.inventory.label}}</span>
                </a>
                <a class="item sla-tab-rail-btn {{tabs.effects.cssClass}}" href="#" data-group="primary" data-tab="effects"
                    title="{{tabs.effects.label}}">
                    <i class="fas {{tabs.effects.icon}}"></i>
                    <span class="sla-tab-rail-tooltip">{{tabs.effects.label}}</span>
                </a>
                <a class="item sla-tab-rail-btn {{tabs.skills.cssClass}}" href="#" data-group="primary" data-tab="skills"
                    title="{{tabs.skills.label}}">
                    <i class="fas {{tabs.skills.icon}}"></i>
                    <span class="sla-tab-rail-tooltip">{{tabs.skills.label}}</span>
                </a>
                <a class="item sla-tab-rail-btn {{tabs.notes.cssClass}}" href="#" data-group="primary" data-tab="notes"
                    title="{{tabs.notes.label}}">
                    <i class="fas {{tabs.notes.icon}}"></i>
                    <span class="sla-tab-rail-tooltip">{{tabs.notes.label}}</span>
                </a>
            </nav>
        </div>
    </div>
</div>

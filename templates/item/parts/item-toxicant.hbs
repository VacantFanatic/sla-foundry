{{!-- Bio-Hazard Notice — toxicant item layout (#243 phase 4) --}}
<div class="bio-hazard-notice">

    <div class="bio-hazard-notice__stamp">{{localize "SLA.ItemSheet.Toxicant.Stamp"}}</div>

    <section class="sla-section bio-hazard-notice__exposure">
        <div class="sla-section__header">
            <span class="sla-section__icon"><i class="fas fa-biohazard"></i></span>
            <span class="sla-section__title">{{localize "SLA.ItemSheet.Toxicant.ExposureData"}}</span>
        </div>

        <div class="bio-hazard-notice__stats">
            <div class="sla-field sla-field--compact">
                <label>{{localize "SLA.ItemSheet.Toxicant.InfectionRating"}}</label>
                <input type="number" name="system.infectionRating" value="{{system.infectionRating}}" min="0" step="1" />
            </div>
            <div class="sla-field sla-field--compact">
                <label>{{localize "SLA.ItemSheet.Toxicant.TreatmentRating"}}</label>
                <input type="number" name="system.treatmentRating" value="{{system.treatmentRating}}" min="0" step="1" />
            </div>
        </div>

        <div class="sla-field">
            <label>{{localize "SLA.ItemSheet.Toxicant.Vectors"}}</label>
            <input type="text" name="system.vector" value="{{system.vector}}" placeholder="{{localize "SLA.ItemSheet.Toxicant.VectorsPlaceholder"}}" />
        </div>

        <div class="sla-field">
            <label>{{localize "SLA.ItemSheet.Toxicant.Progression"}}</label>
            <textarea name="system.progression" rows="2">{{system.progression}}</textarea>
        </div>

        <div class="sla-field">
            <label>{{localize "SLA.ItemSheet.Toxicant.Treatment"}}</label>
            <textarea name="system.treatment" rows="3">{{system.treatment}}</textarea>
        </div>
    </section>

    <p class="bio-hazard-notice__hint">{{localize "SLA.ItemSheet.Toxicant.EffectsHint"}}</p>
</div>

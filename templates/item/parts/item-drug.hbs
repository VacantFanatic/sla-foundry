{{!-- Pharma Label — combat drug item layout (#243 phase 4) --}}
<div class="pharma-label">

    <div class="pharma-label__stamp">{{localize "SLA.ItemSheet.Drug.Stamp"}}</div>

    <div class="pharma-label__grid">
        <div class="sla-field sla-field--compact">
            <label>{{localize "SLA.ItemSheet.Field.Weight"}}</label>
            <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" />
        </div>
        <div class="sla-field sla-field--compact">
            <label>{{localize "SLA.ItemSheet.Field.Cost"}}</label>
            <input type="number" name="system.price" value="{{system.price}}" />
        </div>
        <div class="sla-field sla-field--compact">
            <label>{{localize "SLA.ItemSheet.Field.Qty"}}</label>
            <input type="number" name="system.quantity" value="{{system.quantity}}" />
        </div>
    </div>

    <section class="sla-section pharma-label__pharmacology">
        <div class="sla-section__header">
            <span class="sla-section__icon"><i class="fas fa-syringe"></i></span>
            <span class="sla-section__title">{{localize "SLA.ItemSheet.Drug.Pharmacology"}}</span>
        </div>

        <div class="pharma-label__stats">
            <div class="sla-field sla-field--compact">
                <label>{{localize "SLA.ItemSheet.Drug.AddictionRating"}}</label>
                <input type="number" name="system.addiction" value="{{system.addiction}}" placeholder="10" />
            </div>
            <div class="sla-field sla-field--compact">
                <label>{{localize "SLA.ItemSheet.Drug.Duration"}}</label>
                <input type="text" name="system.duration" value="{{system.duration}}" placeholder="{{localize "SLA.ItemSheet.Drug.DurationPlaceholder"}}" />
            </div>
        </div>

        <div class="sla-field">
            <label>{{localize "SLA.ItemSheet.Drug.AddictionDose"}}</label>
            <input type="text" name="system.addictionDose" value="{{system.addictionDose}}" placeholder="{{localize "SLA.ItemSheet.Drug.AddictionDosePlaceholder"}}" />
        </div>

        <div class="sla-field">
            <label>{{localize "SLA.ItemSheet.Drug.DetoxEffects"}}</label>
            <textarea name="system.detoxEffects" rows="3">{{system.detoxEffects}}</textarea>
        </div>
    </section>
</div>

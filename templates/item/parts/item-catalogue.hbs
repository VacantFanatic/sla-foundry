{{#if (eq item.type "weapon")}}
{{> "systems/sla-industries/templates/item/parts/item-weapon.hbs"}}

{{else if (eq item.type "magazine")}}
{{> "systems/sla-industries/templates/item/parts/item-magazine.hbs"}}

{{else if (eq item.type "armor")}}
{{> "systems/sla-industries/templates/item/parts/item-armor.hbs"}}

{{else if (eq item.type "explosive")}}
{{> "systems/sla-industries/templates/item/parts/item-explosive.hbs"}}

{{else if (eq item.type "drug")}}
{{> "systems/sla-industries/templates/item/parts/item-drug.hbs"}}

{{else if (eq item.type "toxicant")}}
{{> "systems/sla-industries/templates/item/parts/item-toxicant.hbs"}}

{{else if (eq item.type "item")}}
{{> "systems/sla-industries/templates/item/parts/item-item.hbs"}}

{{else}}
{{!-- Remaining catalogue types (e.g. vehicle placeholder) --}}
<div class="catalogue-grid">
    {{!-- COMMON FIELDS (Shared by all physical items) --}}
    <div class="form-group">
        <label>Weight</label>
        <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" />
    </div>
    <div class="form-group">
        <label>Cost</label>
        <input type="number" name="system.price" value="{{system.price}}" />
    </div>
    <div class="form-group">
        <label>Qty</label>
        <input type="number" name="system.quantity" value="{{system.quantity}}" />
    </div>

    {{!-- DYNAMIC PARTIALS — vehicle only until removed in PR 7 --}}

</div>
{{/if}}